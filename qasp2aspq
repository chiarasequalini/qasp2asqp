import fileinput

#input management

source = []

for line in fileinput.input(encoding="utf-8"):
    source.append(line)

#parsing the source file and dividing it into the quantifiers and the program

quantifiers = []
constraints = []

for x in source:
    if ("_exists" in x or "_forall" in x or "_quantify" in x) and not("#show" in x):
        quantifiers.append(x)
    else:
        constraints.append(x)

#reordering the quantifiers based on their index 

quantReorder = [[col for col in range(2)] for row in range(len(quantifiers))]

for i in range(len(quantifiers)):
    quantReorder[i][0] = int(quantifiers[i].split('(')[1].split(',')[0])
    quantReorder[i][1] = quantifiers[i]

quantReorder.sort()

#formatting the quantifiers
#ex: _exists(1,a) becomes
#%@exists
#{a}.

translation = ""

for i in range(len(quantReorder)):
    if "_exists" in quantReorder[i][1] or ("_quantify" in quantReorder[i][1] and quantReorder[i][0] % 2 == 0):
        translation = translation + "%@exists \n"
    else:
        translation = translation + "%@forall \n"
    q = quantReorder[i][1].split(',',1)[1].split(') ')[0].split(').')[0])
    translation = translation + "{" + q + "}"
    if ":-" in quantReorder[i][1]:
        translation = translation + " :- " + quantReorder[i][1].split('-')[1] + "\n"
    else:
        translation = translation + ". \n"

#formatting the program and the empty constraints

translation = translation + "%@exists \n"

for x in constraints:
    if not "#show" in x:
        translation = translation + x + "\n"

translation = translation + "%@constraint \n"

#output

print(translation)
